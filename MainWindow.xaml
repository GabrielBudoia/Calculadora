<Window x:Class="Calculadora.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculadora"
        mc:Ignorable="d"
        Title="Calculadora" Height="620" Width="420">

    <Window.Resources>

        <local:TextToGeometryConverter x:Key="TextToGeometryConverter"/>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            CornerRadius="15" 
                            Padding="10" 
                            BorderBrush="Gray"
                            BorderThickness="1" 
                            Background="White"
                                Margin="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#B0B0B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C8C8C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                    CornerRadius="15" 
                    Padding="5" 
                    BorderBrush="Gray"
                    BorderThickness="1" 
                    Background="White"
                        Margin="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#B0B0B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C8C8C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>

    <Grid>
        <Border
                CornerRadius="20"
                Background="#1E1E2F"
                Padding="10"
                Margin="20">

            <Grid>


                <Grid.RowDefinitions>

                    <RowDefinition Height="140"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    BorderThickness="1"
                    BorderBrush="DarkGray"
                    CornerRadius="10">

                    <Grid>

                        <TextBlock x:Name="DisplaySecundario"
                                    FontSize="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,10,10,0"
                                    Foreground="White"
                                    Opacity="0.6"/>

                        <TextBlock
                        
                        Text="0"
                        x:Name="DisplayText"
                        Visibility="Collapsed"
                        
                    
                            />

                        <Viewbox Stretch="Uniform"
                                 VerticalAlignment="Bottom"
                                 HorizontalAlignment="Right"
                                 Margin="0,0,0,10" Height="59" Width="342">
                            <Path Data="{Binding Text, ElementName=DisplayText, Converter={StaticResource TextToGeometryConverter}}"
                                  Stroke="White"
                                  StrokeThickness="1"
                                  StrokeDashArray="20 1" Height="58" Stretch="Fill"/>
                        </Viewbox>
                    </Grid>
                </Border>



                <Button Tag="AC" Grid.Column="0" Grid.Row="2" Content="AC" Style="{StaticResource MiniButton}" Click="OpClick"/>
                <Button Tag="C" Grid.Column="1" Grid.Row="2" Content="C" Style="{StaticResource MiniButton}" Click="OpClick"/>
                <Button Tag="Root" Grid.Column="2" Grid.Row="2" Content="√" Style="{StaticResource MiniButton}" Click="OpClick"/>
                <Button Tag="Divide" Grid.Column="3" Grid.Row="2" Content="÷" Style="{StaticResource MiniButton}" Click="OpClick"/>
                <Button Tag="MRC" Grid.Column="0" Grid.Row="3" Content="MRC" Style="{StaticResource MiniButton}" Click="OpClick"/>
                <Button Tag="NegativeMatriz" Grid.Column="1" Grid.Row="3" Content="M-" Style="{StaticResource MiniButton}" Click="OpClick"/>
                <Button Tag="PositiveMatriz" Grid.Column="2" Grid.Row="3" Content="M+" Style="{StaticResource MiniButton}" Click="OpClick"/>
                <Button Tag="Times" Grid.Column="3" Grid.Row="3" Content="X" Style="{StaticResource MiniButton}" Click="OpClick"/>


                <Button Click="Button_Click"
                        Tag="Zero"
                        Grid.Column="0" 
                        Grid.ColumnSpan="2" 
                        Grid.Row="7"
                        Style="{StaticResource RoundedButton}"
                        Content="0"                          
                        />

                <Button Click="EqualsClick" 
                        Tag="Equal"
                        Grid.Column="4" 
                        Grid.RowSpan="2" 
                        Grid.Row="6"
                        Style="{StaticResource RoundedButton}"
                        Content="=" 
                        />





                <Button Click="Button_Click"
                        Grid.Column="0"         
                        Grid.Row="4"
                        Style="{StaticResource RoundedButton}"
                        Content="7"  
                        />

                <Button Click="Button_Click"
                        Grid.Column="0"          
                        Grid.Row="5"
                        Style="{StaticResource RoundedButton}"
                        Content="4"  
                         />

                <Button Click="Button_Click"
                        Grid.Column="0"
                        Grid.Row="6"
                        Style="{StaticResource RoundedButton}"
                        Content="1" 
                        />





                <Button Click="Button_Click"
                        Grid.Column="1"         
                        Grid.Row="4"
                        Style="{StaticResource RoundedButton}"
                        Content="8"  
                        />

                <Button Click="Button_Click"
                        Grid.Column="1"          
                        Grid.Row="5"
                        Style="{StaticResource RoundedButton}"
                        Content="5"  
                         />

                <Button 
                        Click="Button_Click"
                        Grid.Column="1"
                        Grid.Row="6"
                        Style="{StaticResource RoundedButton}"
                        Content="2" 
                        />





                <Button 
                        Click="Button_Click"
                        Grid.Column="2"         
                        Grid.Row="4"
                        Style="{StaticResource RoundedButton}"
                        Content="9"  
                        />

                <Button Click="Button_Click"
                        Grid.Column="2"          
                        Grid.Row="5"
                        Style="{StaticResource RoundedButton}"
                        Content="6"  
                         />

                <Button Click="Button_Click"
                        Grid.Column="2"
                        Grid.Row="6"
                        Style="{StaticResource RoundedButton}"
                        Content="3" 
                        />




                <Button Click="OpClick" 
                        Tag="Minus"
                        Grid.Column="3"
                        Grid.Row="4"
                        Style="{StaticResource RoundedButton}"
                        Content="-" 
                        />

                <Button Click="OpClick" 
                        Tag="Plus"
                        Grid.Column="3"          
                        Grid.Row="5"
                        Style="{StaticResource RoundedButton}"
                        Content="+"  
                         />


                <Button Click="OpClick"    
                        Tag="Point"
                        Grid.Column="2"
                        Grid.Row="7"
                        Style="{StaticResource RoundedButton}"
                        Content="." 
                        />




            </Grid>

        </Border>



    </Grid>

</Window>
